<?xml version="1.0" encoding="utf-8"?>
<!--
    Erlaubt ausschließlich HTTPS-Verbindungen.
    Die APIs (Binance, CryptoCompare, CoinGecko usw.) nutzen alle HTTPS,
    also ist cleartext-Traffic nicht nötig.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
